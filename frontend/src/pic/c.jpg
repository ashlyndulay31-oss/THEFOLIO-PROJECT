<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 300" width="400" height="300">
  <defs>
    <linearGradient id="grad2" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4ECDC4;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#44A08D;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="400" height="300" fill="url(#grad2)"/>
  <circle cx="100" cy="80" r="40" fill="rgba(255,255,255,0.3)"/>
  <circle cx="300" cy="150" r="50" fill="rgba(255,255,255,0.2)"/>
  <text x="200" y="160" font-size="20" text-anchor="middle" fill="white" font-weight="bold">My Journey</text>
  <text x="200" y="200" font-size="14" text-anchor="middle" fill="white">From Beginner to Advanced</text>
</svg>
